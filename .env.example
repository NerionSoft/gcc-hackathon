# Civic Property Intelligence — environment variables
# Copy to .env and fill in what you need. Everything is optional:
# the app boots and the demo data pipeline runs with no env at all.

# --- LLM (Mastra agents, phases 2+) -----------------------------------------
# OpenAI API key, used through Mastra's model router (provider "openai").
OPENAI_API_KEY=""

# --- Keyed open-data sources (free keys, optional) ---------------------------
# EPC open data (epc.opendatacommunities.org). Register free, then set the
# "Basic <base64(email:key)>" credential pieces here. Without it the EPC
# connector reports a typed "data gap / key missing" result (no fake data).
# Format: your registered email and key joined as email:key, base64-encoded.
EPC_API_KEY=""

# Companies House REST API key (developer.company-information.service.gov.uk).
# Free registration. Without it the connector reports "data gap / key missing".
COMPANIES_HOUSE_API_KEY=""

# --- Storage -----------------------------------------------------------------
# Local SQLite file for the business model. Created by `pnpm seed`.
SQLITE_PATH="data/cpi.db"

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# pino log level: trace | debug | info | warn | error
LOG_LEVEL="info"
