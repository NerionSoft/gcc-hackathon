# Civic Property Intelligence — environment variables
# Copy to .env and fill in what you need. Everything is optional:
# the app boots and the demo data pipeline runs with no env at all.

# --- LLM (Mastra agents, phases 2+) -----------------------------------------
# OpenAI-compatible API used through Mastra's model router (provider "openai").
# We host on Venice.ai with DeepSeek models for the agents:
#   OPENAI_BASE_URL="https://api.venice.ai/api/v1"
#   OPENAI_MODEL="deepseek-v4-pro"    # also on Venice: deepseek-v4-flash, deepseek-v3.2
# Never commit the real key.
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.venice.ai/api/v1"
# Model for assessment-composer + verdict-adjudicator (default deepseek-v4-pro).
OPENAI_MODEL=""
# Model for the 6 investigators (default deepseek-v4-flash — fast & cheap).
OPENAI_INVESTIGATOR_MODEL=""

# --- Keyed open-data sources (free keys, optional) ---------------------------
# EPC open data — "Get energy performance data" service
# (get-energy-performance-data.communities.gov.uk; successor to
# epc.opendatacommunities.org). Create a free account (GOV.UK One Login),
# copy the bearer token from your account page. Without it the EPC
# connector reports a typed "data gap / key missing" result (no fake data).
EPC_API_KEY=""

# Companies House REST API key (developer.company-information.service.gov.uk).
# Free registration. Without it the connector reports "data gap / key missing".
COMPANIES_HOUSE_API_KEY=""

# HM Land Registry "Use land and property data" API key
# (use-land-property-data.service.gov.uk) for the CCOD/OCOD corporate-ownership
# datasets. Free registration. Without it the connector reports "data gap".
LR_DATA_API_KEY=""

# --- Storage -----------------------------------------------------------------
# Local SQLite file for the business model. Created by `pnpm seed`.
SQLITE_PATH="data/cpi.db"

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# pino log level: trace | debug | info | warn | error
LOG_LEVEL="info"
