# TerraVista — environment variables
# Copy to .env and fill in what you need. Everything is optional: the app
# boots and produces a full report with zero env vars (deterministic rule
# engine + templated narrative; the LLM only adds nuance on top).

# --- LLM (Mastra Analyste + Conseiller agents) -------------------------------
# OpenAI-compatible API used through Mastra's built-in model router
# (provider "openai" — works with any OpenAI-compatible base URL, e.g. Venice.ai).
# Without a key, the Analyste/Conseiller fall back to the deterministic rule
# engine + templated composer — no report ever depends on the LLM being up.
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
# Model for the Analyste (cross-domain reasoning) and Conseiller (report composer).
OPENAI_MODEL="gpt-4o-mini"

# --- Keyed open-data sources (free keys, optional) ---------------------------
# Geod'air (LCSQA) fine-grained pollutant measurements (PM2.5, PM10, NO2, O3, SO2).
# Free registration at geodair.developpement-durable.gouv.fr. Without it, the
# airTool falls back to the Atmo Data daily ATMO index (no key required).
GEODAIR_API_KEY=""

# --- Cache --------------------------------------------------------------------
# Directory for the on-disk JSON cache of slow-changing source responses
# (risks, DVF, crime, energy). Air quality is never cached beyond its own TTL.
DATA_CACHE_DIR="data/cache"

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# pino log level: trace | debug | info | warn | error
LOG_LEVEL="info"
